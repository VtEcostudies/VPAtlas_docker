# VPAtlas Docker environment
# Copy to .env and adjust values

# Database
DB_HOST=db_vp
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=vpatlas

# API
API_PROT=http
API_HOST=localhost
API_PORT=4010
API_SECRET=change-me-in-production

# UI
UI_PROT=http
UI_HOST=localhost
UI_PORT=8090

# Email (for registration/reset)
APP_EMAIL=vpatlas@vtecostudies.org
EMAIL_PASSWORD=

# Service Worker (set to false to disable during development)
USE_SERVICE_WORKER=false
